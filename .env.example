# ─────────────────────────────────────────────
# RotaPay Backend — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# Default client URL — fallback used to build email links when a request
# carries no recognisable client signal.
CLIENT_URL=http://localhost:3000

# Per-client base URLs for email links (verify / reset / welcome).
# The backend picks the right one per request: browsers are matched by their
# Origin header (web app needs no changes); the native app declares itself via
# the `X-Client` header ("mobile-local" in dev, "mobile" in a Play Store build).
# Override these only if a URL changes; the defaults match the current setup.
CLIENT_URL_WEB_LOCAL=http://localhost:3000
CLIENT_URL_WEB_PROD=https://roto-pay-admin-web-app.vercel.app
CLIENT_URL_MOBILE_LOCAL=http://localhost:8081
CLIENT_URL_MOBILE=rotopay://

# MongoDB (MongoDB Atlas connection string)
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rotapay?retryWrites=true&w=majority"

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET=your_super_secret_access_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email — Gmail SMTP (jadvixwork@gmail.com)
# You must use an App Password, NOT your regular Gmail password.
# Guide: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=jadvixwork@gmail.com
SMTP_PASS=your_gmail_app_password_here
EMAIL_FROM_NAME=RotaPay
EMAIL_FROM_ADDRESS=jadvixwork@gmail.com

# Google OAuth
# Guide: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email Verification Token Expiry (in hours)
EMAIL_VERIFY_TOKEN_EXPIRES_HOURS=24

# Bcrypt rounds
BCRYPT_ROUNDS=12

# ImageKit.io (profile picture storage)
# Guide: imagekit.io → Developer options → API Keys
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_PUBLIC_KEY=public_your_public_key
IMAGEKIT_PRIVATE_KEY=private_your_private_key

# ─────────────────────────────────────────────
# SECURITY (blueprint points 1–4)
# ALL optional — each has a safe default in code, so you can leave them unset.
# The "*_ENFORCED" switches default to OFF; turn them on ONLY when the matching
# client side is ready, or you'll lock out real users.
# ─────────────────────────────────────────────

# ── Point 1: behind a load balancer / Cloud Armor ──
# Trusted reverse-proxy hops so the app reads the real client IP from
# X-Forwarded-For. 1 = one LB in front (Cloud Run). Defaults: 1 in production,
# 0 otherwise. Leave unset unless you need to override.
# TRUST_PROXY=1

# ── Point 2: App Attestation (Play Integrity / App Attest) ──
# Master switch. Keep false until the production mobile builds ship attestation.
ATTESTATION_ENFORCED=false
# Signs the attestation challenge + token (falls back to JWT_ACCESS_SECRET if unset).
# ATTESTATION_SECRET=generate_a_random_32+_char_secret
# ATTESTATION_TOKEN_TTL=1h
# ATTESTATION_CHALLENGE_TTL=5m
# Android — Play Integrity (needs a service account with Play Integrity access via ADC):
# ANDROID_PACKAGE_NAME=com.jadvix.rotopay
# GCP_PROJECT_NUMBER=1234567890
# iOS — App Attest:
# APPLE_TEAM_ID=ABCDE12345
# APPLE_BUNDLE_ID=com.jadvix.rotopay
# APP_ATTEST_ENV=development           # development | production
# APPLE_APP_ATTEST_ROOT_CA_PATH=certs/Apple_App_Attestation_Root_CA.pem

# ── Point 4: reCAPTCHA v3 (web bot mitigation) ──
# Keep false until you create reCAPTCHA v3 keys + the web app sends tokens.
RECAPTCHA_ENFORCED=false
# RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key
# RECAPTCHA_MIN_SCORE=0.5              # 0.0 (bot) … 1.0 (human)
