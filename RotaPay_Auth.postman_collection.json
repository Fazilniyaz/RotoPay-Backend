{
  "info": {
    "name": "RotaPay API — Auth Module",
    "description": "Complete test collection for RotaPay authentication endpoints.\n\n**Setup:**\n1. Import this file into Postman\n2. Set the `baseUrl` variable to `http://localhost:5000`\n3. Run the requests in order (Register → Verify Email → Login)\n\n**Variables auto-set by tests:**\n- `accessToken` — set after login\n- `refreshToken` — set after login\n- `verifyToken` — copy from your email or DB",
    "_postman_id": "rotapay-auth-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "verifyToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🏥 Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        },
        "description": "Verify the server is running before testing auth endpoints."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Server is running', () => {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().success).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "1️⃣ Register — Success",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"TestPass123\",\n  \"displayName\": \"Test User\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        },
        "description": "**Expected:** 201 Created\n\nCreates a new account. An email is sent to `testuser@example.com` with the verification link.\n\n**Note:** Check the server console for the verification token in development mode, or check your email inbox."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Register returns 201', () => {",
              "  pm.response.to.have.status(201);",
              "});",
              "pm.test('Response has user data', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.success).to.be.true;",
              "  pm.expect(body.data.user.email).to.equal('testuser@example.com');",
              "  pm.expect(body.data.user).to.not.have.property('password');",
              "  pm.expect(body.data.user.emailVerified).to.be.false;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "1️⃣ Register — Validation Error (weak password)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"weak\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        },
        "description": "**Expected:** 422 Unprocessable Entity\n\nPassword is too short and doesn't meet complexity requirements."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 422 for weak password', () => {",
              "  pm.response.to.have.status(422);",
              "  const body = pm.response.json();",
              "  pm.expect(body.success).to.be.false;",
              "  pm.expect(body.errors).to.have.property('password');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
