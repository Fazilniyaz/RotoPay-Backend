    {
      "name": "5️⃣ Resend Verification — Non-existent Email",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"doesnotexist@example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/resend-verification",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "resend-verification"]
        },
        "description": "**Expected:** 200 OK (intentionally generic — prevents email enumeration)\n\nEven if the email doesn't exist, we return a success message so attackers can't probe for valid emails."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 200 even for non-existent email (anti-enumeration)', () => {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().success).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2️⃣ Login — Success",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"TestPass123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        },
        "description": "**Expected:** 200 OK\n\n**Run this AFTER verifying your email.** Returns access and refresh tokens.\n\nTokens are auto-saved to the collection variables `accessToken` and `refreshToken`."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login returns 200', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has tokens', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.success).to.be.true;",
              "  pm.expect(body.data).to.have.property('accessToken');",
              "  pm.expect(body.data).to.have.property('refreshToken');",
              "  pm.expect(body.data.user.emailVerified).to.be.true;",
              "  // Auto-save tokens for other requests",
              "  pm.collectionVariables.set('accessToken', body.data.accessToken);",
              "  pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
              "  console.log('✅ Tokens saved to collection variables');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
