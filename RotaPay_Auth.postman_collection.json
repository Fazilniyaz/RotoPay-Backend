    {
      "name": "🔐 Protected Route Test (uses saved accessToken)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "me"]
        },
        "description": "**Expected:** 404 (route not built yet) or 200 once user routes are built.\n\nThis tests that the saved `accessToken` is being sent correctly in the Authorization header.\n\nIf you get 401, your token may have expired (15 min expiry) — run Login again."
      },
