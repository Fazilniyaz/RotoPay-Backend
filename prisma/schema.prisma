// ─────────────────────────────────────────────
// RotaPay — Prisma Schema (MongoDB)
// ─────────────────────────────────────────────

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ──────────────── USER ────────────────

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  email          String   @unique
  password       String?
  displayName    String?
  profilePicture String?
  // ImageKit fileId for the current profilePicture — needed to delete the
  // previous image from ImageKit when the user changes their photo.
  profilePictureId String?
  emailVerified  Boolean  @default(false)
  googleId       String?
  pin            String?
  pinEnabled     Boolean  @default(false)

  // The employee that currently scopes the per-employee modules (calendar,
  // earnings, reports). Set to the first employer on onboarding; switchable in
  // the Employees module. Stored as a plain id (no Prisma relation) to avoid a
  // second User↔Employer relation clashing with `employers[]`.
  defaultEmployerId String? @db.ObjectId

  // Email verification
  emailVerifyToken        String?
  emailVerifyTokenExpiry  DateTime?

  // Password reset
  passwordResetToken        String?
  passwordResetTokenExpiry  DateTime?

  // Brute-force / credential-stuffing defense (per-account, works across IPs and
  // serverless instances since it lives in the DB). Counts consecutive failed
  // logins; after a threshold the account locks until `lockedUntil`. Both reset
  // on a successful login. Optional so existing users read fine.
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  settings        UserSettings?
  employers       Employer[]
  shifts          Shift[]
  salaries        Salary[]
  clockSessions   ClockSession[]
  calendarEntries CalendarEntry[]
  notifications   Notification[]
  sessions        Session[]
  paidMonths      PaidMonth[]
  reports         Report[]

  @@map("users")
}

// ──────────────── REPORT ────────────────
// A generated export snapshot (shifts, wages, earnings, …) for a period.
// Retention: only the last 3 months of reports are kept per user — older ones
// are pruned whenever a new report is generated.

model Report {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  months      Int // window length the report covers (1–3)
  periodStart DateTime
  periodEnd   DateTime
  data        Json // computed snapshot (totals, shifts, wages, payments)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("reports")
}

// ──────────────── PAID MONTH ────────────────
// Records that the user has "received salary" for a given month. The `amount`
// is a snapshot of the summed wage values of all shifts whose date falls in
// that month, taken when the month is marked paid. Drives the shift module's
// "This Month Pay" and "Total Pay" tabs.

model PaidMonth {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  // Per-employee scope: which employee this "salary received" belongs to. Null
  // = legacy (pre-default-employee) records. New records always carry it, so
  // Total Pay differs per employee (a fresh employee shows 0).
  employerId String? @db.ObjectId
  year      Int
  month     Int // 1–12
  amount    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  employer Employer? @relation(fields: [employerId], references: [id], onDelete: Cascade)

  // One paid record per employee per month.
  @@unique([userId, employerId, year, month])
  @@index([userId])
  @@index([userId, employerId])
  @@map("paid_months")
}

// ──────────────── USER SETTINGS (1:1) ────────────────

model UserSettings {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                 String   @unique @db.ObjectId
  theme                  String   @default("light")
  // Global currency — used for money formatting across the whole app.
  currency               String   @default("GBP")
  // Native/home currency — optional; when unset it falls back to `currency`.
  // Only the shift module's "Native Pay" tab converts into this.
  nativeCurrency         String?
  salaryCalcMode         String   @default("automatic")
  clockInOutEnabled      Boolean  @default(true)
  // How clock-in happens for the current shift: "automatic" (default) fires via
  // the scheduler when a shift starts/ends; "manual" leaves it to the user.
  clockInType            String   @default("automatic")
  language               String   @default("en")
  dateFormat             String   @default("DD/MM/YYYY")
  // 12-hour AM/PM by default; the user can switch to 24h in Settings.
  timeFormat             String   @default("12h")
  notifyShiftReminder    Boolean  @default(true)
  // How many months back a report export covers (1–3). Optional so existing
  // settings docs don't break on read; defaults to 1 in the controller.
  reportMonths           Int?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ──────────────── EMPLOYER ────────────────

model Employer {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  store         String
  employerName  String
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  // A shift preset is assigned to exactly one employee. Deleting the employee
  // sets shift.employerId to null (the preset itself is kept).
  shifts          Shift[]
  // Wages still carry the employer too (auto-derived from the shift's employer).
  // Deleting an employer sets salary.employerId to null (salary rows are kept).
  salaries        Salary[]
  clockSessions   ClockSession[]
  calendarEntries CalendarEntry[]
  // Per-employee "salary received" records (deleting the employee removes them).
  paidMonths      PaidMonth[]

  @@index([userId])
  @@map("employers")
}

// ──────────────── SHIFT ────────────────
// A shift is a reusable PRESET / template (e.g. "Morning 9–5 for Fazil"), NOT a
// single dated day. It has NO date of its own — `startTime`/`endTime` carry only
// a time-of-day (stored against an arbitrary reference day; end <= start means
// the shift runs past midnight). A preset is assigned onto specific calendar days
// via CalendarEntry(type="shift"), and each such assignment is one worked
// occurrence — that is what drives hours, pay, reports and the auto-clock.
// A preset belongs to exactly ONE employee (employerId).

model Shift {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  userId        String       @db.ObjectId
  shiftName     String?
  // Time-of-day only — the date component is meaningless for a preset.
  startTime     DateTime
  endTime       DateTime
  totalHours    Float
  // Free-form type: day | night | rotational, OR a user-supplied custom label.
  shiftType     String?
  // Label colour chosen when the shift is created; the calendar renders shift
  // assignments in this colour (events/memos keep their own calendar colour).
  color         String?
  // The single employee this preset is allocated to.
  employerId    String?      @db.ObjectId
  isManualEntry Boolean      @default(false)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employer Employer? @relation(fields: [employerId], references: [id], onDelete: SetNull)
  // Deleting a preset also deletes its wages and its calendar assignments
  // (both are meaningless without it — onDelete: Cascade on those relations).
  salaries        Salary[]
  calendarEntries CalendarEntry[]
  clockSessions   ClockSession[]

  @@index([userId])
  @@index([userId, employerId])
  @@map("shifts")
}

// ──────────────── CALENDAR ENTRY ────────────────
// A user-marked note on a calendar day (e.g. "Gym session", "Holiday").
// `title` is free custom text (max 15 words). Optionally links to a Shift.

model CalendarEntry {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  date      DateTime
  // What this entry represents on the calendar: event | memo | shift (a label
  // that surfaces an existing shift on the calendar with a chosen colour).
  type      String   @default("memo")
  title     String
  shiftId   String?  @db.ObjectId
  // Optional employee scope — entries created while viewing one employee's
  // calendar. Null = the user's own (default) calendar.
  employerId String? @db.ObjectId
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // A `type="shift"` entry (assignment) is meaningless without its preset — it is
  // removed when the shift is deleted.
  shift    Shift?    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  employer Employer? @relation(fields: [employerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@index([employerId])
  @@map("calendar_entries")
}

// ──────────────── SALARY ────────────────
// The wage (hourly rate) for a shift PRESET; its employee is the shift's employer.
// A wage is meaningless without its preset (pay = rate × the preset's hours), so
// deleting the shift DELETES its wages (onDelete: Cascade). When the EMPLOYER is
// deleted the wage is kept with employerId set to null (it still has its shift).

model Salary {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  shiftId       String?  @db.ObjectId
  employerId    String?  @db.ObjectId
  salary        Float?
  // Wage rate basis: hourly | weekly | monthly.
  rateType      String   @default("hourly")
  // Display currency (3-letter ISO). Totals still assume the global Settings
  // currency; this is recorded per-wage for display.
  currency      String?
  // Auto-derived = salary / shift.totalHours (computed server-side).
  hourlyPayRate Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  shift         Shift?         @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  employer      Employer?      @relation(fields: [employerId], references: [id], onDelete: SetNull)
  clockSessions ClockSession[]

  @@index([userId])
  @@index([shiftId])
  @@index([employerId])
  @@map("salaries")
}

// ──────────────── CLOCK SESSION ────────────────

model ClockSession {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  userId           String    @db.ObjectId
  employerId       String?   @db.ObjectId
  // Links to the Salary row → carries employer + shift details + hourly rate.
  salaryId         String?   @db.ObjectId
  // Direct link to the shift being clocked — set for auto (scheduler) sessions
  // so we can dedupe/auto-clock-out per shift even when no salary is attached.
  shiftId          String?   @db.ObjectId
  clockInTime      DateTime
  clockOutTime     DateTime?
  totalHours       Float?
  earnings         Float?
  isAutoCalculated Boolean   @default(true)
  status           String    @default("active")
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  employer Employer? @relation(fields: [employerId], references: [id], onDelete: SetNull)
  salary   Salary?   @relation(fields: [salaryId], references: [id], onDelete: SetNull)
  shift    Shift?    @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([employerId])
  @@index([salaryId])
  @@index([userId, status])
  @@index([shiftId])
  @@map("clock_sessions")
}

// ──────────────── NOTIFICATION ────────────────

model Notification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  type        String
  title       String
  message     String
  isRead      Boolean  @default(false)
  relatedId   String?  @db.ObjectId
  relatedType String?
  scheduledAt DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([userId, scheduledAt])
  @@map("notifications")
}

// ──────────────── SESSION ────────────────

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  token        String   @unique
  refreshToken String   @unique
  expiresAt    DateTime
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ──────────────── APP ATTEST KEY (iOS) ────────────────
// One record per iOS App Attest hardware key (Secure Enclave). Created during
// the attestation handshake; every later assertion is verified against the
// stored public key, and `signCount` is monotonically increased to detect
// replay/cloning. Device-level (may exist before the user logs in), so userId
// is optional.

model AppAttestKey {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  // Apple's key identifier (base64) — unique per hardware key.
  keyId     String   @unique
  // Attested public key in PEM (SPKI) form — used to verify future assertions.
  publicKey String
  // Monotonic counter; each assertion must exceed the stored value.
  signCount Int      @default(0)
  bundleId  String?
  userId    String?  @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("app_attest_keys")
}
